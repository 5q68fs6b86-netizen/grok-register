{
  "manifest_version": 3,
  "name": "Turnstile Patch",
  "version": "1.0.0",
  "description": "Patch Turnstile mouse coordinates for automation environments",
  "content_scripts": [
    {
      "js": ["script.js"],
      "matches": ["<all_urls>"],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    }
  ],
  "permissions": [],
  "host_permissions": ["<all_urls>"]
}
